# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Supabase, Neon, Railway Postgres, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
SESSION_SECRET=change-this-to-a-random-string-at-least-32-chars

# ─── AI Models ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Salesforce ──────────────────────────────────────────────────────────────
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
# Must match the callback URL registered in your Salesforce Connected App
SALESFORCE_REDIRECT_URI=https://your-railway-app.up.railway.app/api/salesforce/callback

# ─── Zoom Phone ──────────────────────────────────────────────────────────────
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# ─── Twilio Voice ────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_TWIML_APP_SID=

# ─── Google Workspace ────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ─── Research APIs ───────────────────────────────────────────────────────────
SERP_API=
XAI_API=

# ─── Browserless (deep research mode) ────────────────────────────────────────
BROWSERLESS_API_KEY=
